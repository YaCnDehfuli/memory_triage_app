# Copy to .env and adjust. docker-compose sets the service-to-service values
# itself; this file documents every knob and supports running the API/worker
# outside Docker.

# --- infrastructure ---
MEMTRIAGE_DATABASE_URL=postgresql+psycopg://memtriage:memtriage@localhost:5432/memtriage
MEMTRIAGE_REDIS_URL=redis://localhost:6379/0
MEMTRIAGE_DATA_DIR=/data

# --- API ---
MEMTRIAGE_CORS_ORIGINS=["http://localhost:5173"]

# --- upload / DoS limits ---
# 48 GiB default; 4GB+ dumps are first-class. Value is bytes.
MEMTRIAGE_MAX_UPLOAD_BYTES=51539607552

# --- candidate selection ---
# suspicious_first | all | suspicious_only
MEMTRIAGE_CLASSIFY_SCOPE=suspicious_first
MEMTRIAGE_CANDIDATE_CAP=24

# --- VADViT model (bring your own weights) ---
# Drop the trained checkpoint + a labels.json (9 alphabetical class names)
# under ./models to enable real verdicts. Absent => verdicts show
# "model not loaded" (never a fabricated result).
MEMTRIAGE_MODEL_CHECKPOINT_PATH=/models/Multi_32_224_6f_3u.pt
MEMTRIAGE_LABELS_PATH=/models/labels.json
MEMTRIAGE_DEVICE=cpu

# --- grid geometry (VADViT preprocessing) ---
# Defaults match vit_base_patch32_224 + the 32_224 dataset. Switch to 16/384
# only if confirmed against the real training PNGs.
MEMTRIAGE_PATCH_SIZE=32
MEMTRIAGE_IMAGE_SIZE=224
